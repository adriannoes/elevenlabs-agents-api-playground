# Copy this file to .env and fill in your own values. Never commit the real .env.

# ElevenLabs API key. Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Default voices for the playground and scenarios. Look up voice_ids via scripts/voices_pt_br.py
# ElevenAgents voice resolution: DEFAULT_AGENT_VOICE_ID, then DEFAULT_EN_VOICE_ID, then DEFAULT_PT_VOICE_ID.
# For English Convai demos, set DEFAULT_AGENT_VOICE_ID or DEFAULT_EN_VOICE_ID (not PT-only).
DEFAULT_AGENT_VOICE_ID=
# Example: a Portuguese (BR) voice from the Voice Library (TTS playground, benchmarks; last agent fallback).
DEFAULT_PT_VOICE_ID=
# Example: an English voice from the Voice Library (Convai before PT fallback).
DEFAULT_EN_VOICE_ID=

# Agent IDs: run ``uv run python scripts/demo_prepare.py`` once (writes all three),
# or ``uv run python scripts/agent_create.py <telecom|banking|healthcare>`` and paste each id.
DEMO_AGENT_ID_TELECOM=
DEMO_AGENT_ID_BANKING=
DEMO_AGENT_ID_HEALTHCARE=

# Public HTTPS URL where ElevenLabs can POST webhook tools (live voice demos).
# Prefer one tunnel on Next.js (port 3000): ``https://<public-host>/api/convai/demo-tools``
# so signed URLs and tools share the same origin (`pnpm --dir apps/web run demo`).
# Alternate: expose ws_bridge directly: ``https://<tunnel>/convai/demo-tools``.
# Re-run after tunnel hostname changes: ``uv run python scripts/agent_create.py <scenario>``.
CONVAI_DEMO_TOOL_WEBHOOK_URL=

# Optional: pin specific models. Defaults are picked at runtime.
TTS_MODEL_ID=eleven_flash_v2_5
TTS_OUTPUT_FORMAT=mp3_22050_32
STT_MODEL_ID=scribe_v2
STT_REALTIME_MODEL_ID=scribe_v2_realtime

# Logging level for the demo modules (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Optional: only needed for the TTS vendor benchmark (ElevenLabs vs OpenAI).
# Leave empty if you only want to run the ElevenLabs demos.
OPENAI_API_KEY=
OPENAI_TTS_MODEL_ID=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_RESPONSE_FORMAT=mp3
