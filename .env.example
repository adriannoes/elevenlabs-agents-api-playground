# Copy this file to .env and fill in your own values. Never commit the real .env.

# ElevenLabs API key. Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Default voices for the playground and scenarios. Look up voice_ids via scripts/voices_pt_br.py
# Example: a Portuguese (BR) voice from the Voice Library.
DEFAULT_PT_VOICE_ID=
# Example: an English voice (used by Banking demo for English-speaking customers).
DEFAULT_EN_VOICE_ID=

# Agent IDs are populated after running scripts/agent_create.py <scenario>.
DEMO_AGENT_ID_TELECOM=
DEMO_AGENT_ID_BANKING=
DEMO_AGENT_ID_HEALTHCARE=

# Optional: pin specific models. Defaults are picked at runtime.
TTS_MODEL_ID=eleven_flash_v2_5
TTS_OUTPUT_FORMAT=mp3_22050_32
STT_MODEL_ID=scribe_v1
STT_REALTIME_MODEL_ID=scribe_v2_realtime

# Logging level for the demo modules (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Optional: only needed for the TTS vendor benchmark (ElevenLabs vs OpenAI).
# Leave empty if you only want to run the ElevenLabs demos.
OPENAI_API_KEY=
OPENAI_TTS_MODEL_ID=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_RESPONSE_FORMAT=mp3
