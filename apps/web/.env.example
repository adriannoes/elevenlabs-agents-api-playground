# Copy this file to apps/web/.env.local. Never commit real secrets.

# Server-only ElevenLabs API key used by app/api/signed-url/route.ts.
ELEVENLABS_API_KEY=

# Telecom agent created by `uv run python scripts/agent_create.py telecom`.
DEMO_AGENT_ID_TELECOM=

# Optional: override where Next proxies Convai tool webhooks (default http://127.0.0.1:8788/convai/demo-tools).
# `pnpm run demo` sets this automatically when the stack owns the ws_bridge port.
INTERNAL_WS_BRIDGE_TOOLS_URL=
